# ===========================================================================
# Photo Matcher — .gitignore
# ===========================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
dist/
build/
*.whl

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
photo_matcher_env/
venv/
.venv/
env/

# ---------------------------------------------------------------------------
# ML models (downloaded at runtime, ~326MB)
# ---------------------------------------------------------------------------
models/

# ---------------------------------------------------------------------------
# Cache files (generated at runtime, contain embeddings)
# ---------------------------------------------------------------------------
photo_cache/
.face_cache.pkl

# ---------------------------------------------------------------------------
# Application logs
# ---------------------------------------------------------------------------
photo_matcher.log

# ---------------------------------------------------------------------------
# PyInstaller build artifacts
# ---------------------------------------------------------------------------
*.spec
build/
dist/

# ---------------------------------------------------------------------------
# IDE and editor files
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# OS-generated files
# ---------------------------------------------------------------------------
Desktop.ini
ehthumbs.db