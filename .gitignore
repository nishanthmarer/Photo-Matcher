# ===========================================================================
# Photo Matcher — .gitignore
# ===========================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
*.whl

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
photo_matcher_env/
build_env/
venv/
.venv/
env/

# ---------------------------------------------------------------------------
# ML models (downloaded at runtime, ~326MB)
# ---------------------------------------------------------------------------
models/

# ---------------------------------------------------------------------------
# Cache files (generated at runtime, contain embeddings)
# ---------------------------------------------------------------------------
photo_cache/

# ---------------------------------------------------------------------------
# Application logs
# ---------------------------------------------------------------------------
photo_matcher.log

# ---------------------------------------------------------------------------
# IDE and editor files
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# OS-generated files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db